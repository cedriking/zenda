{
  "name": "@zenda/db",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "./src/prisma-client.ts",
  "types": "./src/prisma-client.ts",
  "exports": {
    ".": "./src/prisma-client.ts",
    "./client": "./src/client.ts",
    "./prisma": "./src/prisma-client.ts",
    "./schema": "./src/prisma-client.ts"
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
