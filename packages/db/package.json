    "studio": "prisma studio",
    "seed": "bun run src/seed/index.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@zenda/shared": "*",
    "prisma": "^7.8.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
