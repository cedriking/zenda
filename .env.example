# Zenda Environment Variables
# Copy this file to .env and fill in the values

# Database
DATABASE_URL=postgres://zenda:zenda_dev@localhost:5432/zenda
DATABASE_SSL=false

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Stripe Price IDs — set after running scripts/stripe-setup.ts
STRIPE_PRICE_LOCAL_SOLO_MONTHLY=price_xxx
STRIPE_PRICE_LOCAL_STARTER_MONTHLY=price_xxx
STRIPE_PRICE_LOCAL_PRO_MONTHLY=price_xxx
STRIPE_PRICE_LOCAL_BUSINESS_MONTHLY=price_xxx

# AI Providers
OPENAI_API_KEY=sk-xxx
ZAI_API_KEY=xxx
# Local Whisper STT server (faster-whisper)
WHISPER_LOCAL_URL=http://192.168.68.131:8001
OLLAMA_BASE_URL=http://localhost:11434

# Storage (S3-compatible)
S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=xxx
S3_SECRET_ACCESS_KEY=xxx
S3_BUCKET=zenda-audio

# API
API_PORT=3001
API_URL=http://localhost:3001

# App
APP_URL=http://localhost:5173

# Update Server
UPDATE_BASE_URL=https://zenda.bot/updates
# R2 public URL for update file serving (used by Next.js rewrites)
R2_UPDATES_PUBLIC_URL=https://pub-xxx.r2.dev

# Desktop App Downloads (S3/R2)
S3_DOWNLOADS_ENDPOINT=https://xxx.r2.cloudflarestorage.com
S3_DOWNLOADS_ACCESS_KEY_ID=xxx
S3_DOWNLOADS_SECRET_ACCESS_KEY=xxx
S3_DOWNLOADS_BUCKET=zenda-downloads
S3_DOWNLOADS_PUBLIC_URL=https://downloads.zenda.bot

# Zernio Integration (Required)
ZERNIO_API_KEY=your_zernio_api_key_here
ZERNIO_WEBHOOK_SECRET=your_webhook_secret_here
ZERNIO_WEBHOOK_URL=https://api.zenda.bot/integrations/zernio/webhook
ZERNIO_API_BASE_URL=https://zernio.com/api

# Composio Integration (Required)
COMPOSIO_API_KEY=your_composio_api_key_here
COMPOSIO_BASE_URL=https://api.composio.dev

# Monitoring (optional — set to protect /monitoring/health in production)
# When set, callers must send Authorization: Bearer <MONITOR_SECRET>
# When unset, /monitoring/health is publicly accessible (safe for internal networks)
# MONITOR_SECRET=your-monitor-secret-here

# Environment
NODE_ENV=development
