# Zenda Environment Variables
# Copy this file to .env and fill in the values

# Database
DATABASE_URL=postgres://zenda:zenda_dev@localhost:5432/zenda
DATABASE_SSL=false

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# Stripe (Live mode keys start with sk_live_ / rk_live_)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Stripe Price IDs — auto-discovered at startup if not set; set explicitly to override
STRIPE_PRICE_LOCAL_SOLO_MONTHLY=price_1TalTwDbZbDfKaIOaaaT5Uj0
STRIPE_PRICE_LOCAL_STARTER_MONTHLY=price_1TalTxDbZbDfKaIOHQuQ2phL
STRIPE_PRICE_LOCAL_PRO_MONTHLY=price_1TalTxDbZbDfKaIO8Axyzaa3
STRIPE_PRICE_LOCAL_BUSINESS_MONTHLY=price_1TalTyDbZbDfKaIOdys4ZVUI

# AI Providers
OPENAI_API_KEY=sk-xxx
ZAI_API_KEY=xxx
# Local Whisper STT server (faster-whisper)
WHISPER_LOCAL_URL=http://192.168.68.131:8001
OLLAMA_BASE_URL=http://localhost:11434

# Storage (S3-compatible)
S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=xxx
S3_SECRET_ACCESS_KEY=xxx
S3_BUCKET=zenda-audio

# API
API_PORT=3001
API_URL=http://localhost:3001

# App
APP_URL=http://localhost:5173

# Update Server
UPDATE_BASE_URL=https://zenda.bot/updates

# Desktop App Downloads (Self-hosted)
DOWNLOADS_DIR=/data/downloads
UPLOAD_SECRET=your_secure_upload_secret_here

# Zernio Integration (Required)
ZERNIO_API_KEY=your_zernio_api_key_here
ZERNIO_WEBHOOK_SECRET=your_webhook_secret_here
ZERNIO_WEBHOOK_URL=https://api.zenda.bot/integrations/zernio/webhook
ZERNIO_API_BASE_URL=https://zernio.com/api

# Google Calendar Integration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://api.zenda.bot/integrations/google/callback
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# Monitoring (optional — set to protect /monitoring/health in production)
# When set, callers must send Authorization: Bearer <MONITOR_SECRET>
# When unset, /monitoring/health is publicly accessible (safe for internal networks)
# MONITOR_SECRET=your-monitor-secret-here

# Email Verification (optional — enables SMTP-level checks via AbstractAPI)
# Free tier: 100 verifications/month at https://app.abstractapi.com/api/email-validation
# ABSTRACT_API_KEY=your_abstract_api_key_here

# Environment
NODE_ENV=development

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Ads conversion tracking
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_SIGNUP_LABEL=xxxxxxxxxx
